      "id": "e35dab75-bacc-4d13-a161-5db590cafd3f",
      "name": "Send Briefing to Slack",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.4,
      "position": [
        2064,
        944
      ],
      "webhookId": "607dc155-c02c-4dac-919c-bc76e3d34690",
      "alwaysOutputData": true,
      "credentials": {
        "slackApi": {
          "id": "J4uyJm8c3ha2y1sq",
          "name": "Slack account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// --- FORMAT DAILY BRIEFING (using Aggregate node data) ---\n\n// 0) Pull EM Copilot configuration (team name, Slack channel, thresholds)\nconst configItems = $items(\"EM Copilot Configuration\");\nconst config = configItems.length ? configItems[0].json : {};\n\n// 1) Pull data from Aggregate Metrics & Flag Risks node\nconst aggItems = $items(\"Aggregate Metrics & Flag Risks\");\nconst agg = aggItems.length ? aggItems[0].json : {};\n\n// 2) Team / channel info\nconst teamName = config.teamName || \"Team Alpha\";\nconst slackChannel = config.slackChannel || \"#em-copilot\";\n\n// 3) Stats & risks\nconst stats = agg.stats || {};\nconst risks = Array.isArray(agg.risks) ? agg.risks : [];\n\n// 4) Build a simple summary\nconst summary =\n  risks.length > 0\n    ? `There are ${risks.length} active risk(s) on your board.`\n    : \"No overall summary available.\";\n\n// 5) Format risks as bullets for Slack\nfunction formatRisks(arr) {\n  if (!arr || !arr.length) return \"_None._\";\n\n  return arr\n    .map((r) => {\n      const owners = Array.isArray(r.owners)\n        ? r.owners.join(\", \")\n        : r.owners || \"n/a\";\n      return `• *${r.type}* – ${r.detail}` +\n        (owners ? ` (owners: ${owners})` : \"\");\n    })\n    .join(\"\\n\");\n}\n\n// 6) Final Slack text\nconst text =\n  `*Daily Team Health – ${teamName}*\\n\\n` +\n  `${summary}\\n\\n` +\n  `*Top Risks:*\\n${formatRisks(risks)}\\n\\n` +\n  `*Recommended Actions:* _None_\\n\\n` +\n  `Automated with this n8n workflow`;\n\n// 7) Return one item for downstream nodes\nreturn {\n  json: {\n    teamName,\n    slackChannel,\n    text,\n    stats,\n    summary,\n    topRisks: risks,\n    actions: [],\n  },\n};"
      },
      "id": "c4fd7a41-1805-4126-b7ca-a8d452077311",
      "name": "Format Daily Briefing",
      "type": "n8n-nodes-base.code",
