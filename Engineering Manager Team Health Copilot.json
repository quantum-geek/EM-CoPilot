      "id": "5b502e4c-1ac8-4a22-96ca-98649b8782c8",
      "name": "Daily EM Briefing Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [
        256,
        848
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "id-1",
              "name": "issueTrackerUrl",
              "value": "https://api.github.com/repos/quantum-geek/EM-CoPilot/issues",
              "type": "string"
            },
            {
              "id": "id-2",
              "name": "githubPrUrl",
              "value": "https://api.github.com/repos/quantum-geek/EM-CoPilot/pulls",
              "type": "string"
            },
            {
              "id": "id-3",
              "name": "slackChannel",
              "value": "#em-copilot",
              "type": "string"
            },
            {
              "id": "id-4",
              "name": "teamName",
              "value": "Team Alpha",
              "type": "string"
            },
            {
              "id": "id-5",
              "name": "staleIssueDays",
              "value": 7,
              "type": "number"
            },
            {
              "id": "id-6",
              "name": "stalePrDays",
              "value": 0,
              "type": "number"
            }
          ]
        },
        "options": {}
      },
      "id": "a0493014-ba63-44ed-a367-54ef3febf608",
      "name": "EM Copilot Configuration",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        480,
        848
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// ---------- 1) Read configuration from \"EM Copilot Configuration\" ----------\nconst cfgItems = $items(\"EM Copilot Configuration\", 0) || [];\nconst cfg = (cfgItems[0] && cfgItems[0].json) || {};\n\n// stalePrDays semantics:\n// - undefined/null/'' => default 7\n// - > 0               => days threshold\n// - 0 or negative     => DEMO mode: treat ALL open PRs as stale\nconst rawStale = cfg.stalePrDays;\nlet stalePrDays;\n\nif (rawStale === undefined || rawStale === null || rawStale === \"\") {\n  stalePrDays = 7;\n} else {\n  stalePrDays = Number(rawStale);\n}\n\n// ---------- 2) Prepare stats & risks ----------\nconst stats = {\n  totalPRs: 0,\n  openPRs: 0,\n};\nconst risks = [];\n\nconst now = new Date();\nconst msPerDay = 1000 * 60 * 60 * 24;\n\n// ---------- 3) Pull PRs directly from \"Fetch GitHub PR Data\" ----------\nconst prItems = $items(\"Fetch GitHub PR Data\", 0) || [];\nconst allPRs = [];\n\nfor (const item of prItems) {\n  const j = item.json;\n\n  if (Array.isArray(j)) {\n    // Some integrations return an array in json\n    allPRs.push(...j);\n  } else if (j && typeof j === \"object\") {\n    // Others return one PR per item\n    allPRs.push(j);\n  }\n}\n\n// ---------- 4) Compute basic stats ----------\nstats.totalPRs = allPRs.length;\n\nconst openPRs = allPRs.filter((pr) => pr.state === \"open\");\nstats.openPRs = openPRs.length;\n\n// ---------- 5) Identify stale PRs ----------\nlet stalePRs = [];\n\nif (!Number.isNaN(stalePrDays)) {\n  if (stalePrDays > 0) {\n    // Normal mode: real \"older than N days\"\n    stalePRs = openPRs.filter((pr) => {\n      const updatedAt = new Date(pr.updated_at || pr.created_at || now);\n      const ageDays = (now - updatedAt) / msPerDay;\n      return ageDays >= stalePrDays;\n    });\n  } else {\n    // DEMO mode: stalePrDays <= 0 → treat ALL open PRs as stale\n    stalePRs = openPRs;\n  }\n}\n\nif (stalePRs.length > 0) {\n  const owners = Array.from(\n    new Set(\n      stalePRs\n        .map((pr) => pr.user && pr.user.login)\n        .filter(Boolean),\n    ),\n  );\n\n  risks.push({\n    type: \"Stale PRs\",\n    detail: `${stalePRs.length} PR(s) older than ${stalePrDays} day(s)`,\n    owners,\n  });\n\n  stats.stalePRs = stalePRs.length;\n}\n\n// ---------- 6) Return one aggregated item ----------\nreturn [\n  {\n    json: {\n      stats,\n      risks,\n      stalePrDaysUsed: stalePrDays,\n      debug: {\n        cfg,\n        prItemsCount: prItems.length,\n        allPRsCount: allPRs.length,\n      },\n    },\n  },\n];"
      },
      "id": "7f658635-1c9d-4045-b2ab-21963478fa55",
      "name": "Aggregate Metrics & Flag Risks",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1152,
        848
      ]
